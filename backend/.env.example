# Copy this file to .env and fill in all values before running locally.
# Never commit .env to git.

TELEGRAM_BOT_TOKEN=          # from @BotFather
GEMINI_API_KEY=               # from https://aistudio.google.com/app/apikey
ANTHROPIC_API_KEY=            # from https://console.anthropic.com — used as fallback when Gemini blocks
ALLOWED_TELEGRAM_USER_ID=    # your numeric Telegram user ID (message @userinfobot)
WEBHOOK_SECRET=               # random string: python -c "import secrets; print(secrets.token_hex(32))"

# Railway sets this automatically in production; not needed for local polling mode
RAILWAY_PUBLIC_DOMAIN=

# Optional: path to Netscape cookies.txt for Instagram auth fallback
# INSTAGRAM_COOKIES_FILE=/app/cookies/instagram_cookies.txt

# Safety cap on Gemini API calls per day (default 50)
DAILY_REQUEST_LIMIT=50
